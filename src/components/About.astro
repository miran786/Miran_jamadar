---
import { Image } from "astro:assets";
import Avatar_250 from "../Avatar_250.webp";
import { SectionTitle } from "./UI";
---

<section id="about" class="w-full min-h-screen px-6 py-4 pt-14 bg-background">
    <SectionTitle
        title="About Me"
        color="primary"
        className="h-screen flex flex-col justify-center"
    >
        <div class="flex_center flex-col lg:flex-row w-full h-full py-10 gap-8">
            <Image
                src={Avatar_250}
                alt="About_Avatar"
                class="Fade_Up rounded-full scale-x-[-1] lg:mx-14"
                width={225}
                height={225}
                loading="lazy"
            />

            <div
                class="Fade_Up w-full md:w-[80%] lg:w-[60%] flex justify-center items-start flex-col gap-4 lg:border-l border-primary py-8 lg:pl-10"
            >
                <h2 class="Fade_Up text-[1.5em] font-bold">Hey there! 👋🏻</h2>
                <p class="Fade_Up text-justify">
                    I'm Miran, a B.Tech CSE (AI) student at VIT Pune and a
                    full stack developer with a deep passion for building secure,
                    intelligent systems that solve real-world problems.
                </p>
                <p class="Fade_Up text-justify">
                    My cybersecurity journey started in 2022 with the MrWebSecure
                    certification, followed by a cybersecurity internship at
                    Learnex in 2023. Since then, I've built StealthGuard VPN from
                    scratch, contributed to OWASP, and co-invented a patent on
                    AI-based anomaly detection. I also specialize in AI/ML and
                    cloud-native development — working across Android, web, and
                    cloud (AWS, Docker, Firebase) with PyTorch, FastAPI, and more.
                </p>
                <p class="Fade_Up text-justify">
                    When I'm not coding, I'm competing in hackathons (Google
                    Developer Code finalist, Fusion 2025 Top 10) or publishing
                    research at IEEE conferences. Let's build something
                    impactful together!
                </p>
            </div>
        </div>

        <!-- <picture class="flex_center">
            <source
                media="(prefers-color-scheme: dark)"
                srcset="https://raw.githubusercontent.com/miran786/miran786/output/github-contribution-grid-snake-dark.svg"
            />
            <img
                alt="github contribution grid snake animation"
                src="https://raw.githubusercontent.com/miran786/miran786/output/github-contribution-grid-snake.svg"
            />
        </picture> -->
    </SectionTitle>
</section>
