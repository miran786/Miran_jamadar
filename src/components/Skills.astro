---
import { CenterTitle, SkillTitle, SkillGrid } from "./UI";
import {
    FrontendStack,
    BackendStack,
    ProgrammingStack,
    ToolsStack,
    SecurityStack,
} from "../utils/SkillStack";
---

<section id="skills" class="w-full min-h-screen px-6 py-4 pt-14 bg-background">
    <CenterTitle title="Tech Stack" color="primary" />

    <div
        class="Fade_Up flex justify-center items-start flex-col lg:flex-row gap-2"
    >
        <div
            class="Fade_Up flex_center flex-col gap-4 py-4 xs:p-4 w-full h-full"
        >
            <SkillTitle title="Front-End" color="primary" />
            <SkillGrid stack={FrontendStack} />
        </div>

        <div
            class="Fade_Up flex_center flex-col gap-4 py-4 xs:p-4 w-full h-full"
        >
            <SkillTitle title="Back-End" color="primary" />
            <SkillGrid stack={BackendStack} />
        </div>
    </div>

    <div class="flex justify-center items-start flex-col lg:flex-row gap-2">
        <div
            class="Fade_Up flex_center flex-col gap-4 py-4 xs:p-4 w-full h-full"
        >
            <SkillTitle title="Programming" color="primary" />
            <SkillGrid stack={ProgrammingStack} />
        </div>

        <div
            class="Fade_Up flex_center flex-col gap-4 py-4 xs:p-4 w-full h-full"
        >
            <SkillTitle title="Cloud & DevOps" color="primary" />
            <SkillGrid stack={ToolsStack} />
        </div>
    </div>

    <!-- Cybersecurity Highlight Section -->
    <div class="Fade_Up w-full mt-8 mb-4">
        <div class="relative w-full max-w-4xl mx-auto rounded-xl overflow-hidden" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(6, 182, 212, 0.08) 50%, rgba(16, 185, 129, 0.05) 100%); border: 1px solid rgba(16, 185, 129, 0.3);">
            <div class="absolute top-0 left-0 w-full h-1" style="background: linear-gradient(90deg, #10b981, #06b6d4, #10b981);"></div>
            <div class="p-6 md:p-8">
                <div class="flex items-center gap-3 mb-4">
                    <div class="flex_center w-10 h-10 rounded-lg" style="background: rgba(16, 185, 129, 0.2);">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            <path d="m9 12 2 2 4-4"/>
                        </svg>
                    </div>
                    <h3 class="font-ubuntu text-[1.4em]" style="background: linear-gradient(90deg, #10b981, #06b6d4); -webkit-background-clip: text; color: transparent;">
                        Cybersecurity & Open Source
                    </h3>
                </div>
                <!-- Experience & Certifications Row -->
                <div class="flex flex-col sm:flex-row gap-3 mb-4">
                    <div class="flex-1 flex items-center gap-3 p-3 rounded-lg" style="background: rgba(16, 185, 129, 0.08); border: 1px solid rgba(16, 185, 129, 0.2);">
                        <div class="flex-shrink-0 flex_center w-10 h-10 rounded-full" style="background: rgba(16, 185, 129, 0.15);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="20" height="14" x="2" y="7" rx="2" ry="2"/>
                                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                            </svg>
                        </div>
                        <div>
                            <span class="font-ubuntu text-[1em]" style="color: #10b981;">Cybersecurity Intern — Learnex</span>
                            <p class="text-[0.85em] mt-0.5 opacity-70">2023 — Hands-on professional cybersecurity training and real-world security practices</p>
                        </div>
                    </div>
                    <div class="flex-1 flex items-center gap-3 p-3 rounded-lg" style="background: rgba(6, 182, 212, 0.08); border: 1px solid rgba(6, 182, 212, 0.2);">
                        <div class="flex-shrink-0 flex_center w-10 h-10 rounded-full" style="background: rgba(6, 182, 212, 0.15);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
                                <line x1="4" x2="4" y1="22" y2="15"/>
                            </svg>
                        </div>
                        <div>
                            <span class="font-ubuntu text-[1em]" style="color: #06b6d4;">MrWebSecure Certification</span>
                            <p class="text-[0.85em] mt-0.5 opacity-70">2022 — Dedicated cybersecurity course covering web security fundamentals and practices</p>
                        </div>
                    </div>
                </div>

                <!-- Skills Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
                    <div class="flex items-start gap-3 p-3 rounded-lg" style="background: rgba(16, 185, 129, 0.05);">
                        <div class="mt-1 flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="m9 12 2 2 4-4"/>
                            </svg>
                        </div>
                        <div>
                            <span class="font-ubuntu text-[1em]" style="color: #10b981;">OWASP Contributor</span>
                            <p class="text-[0.85em] mt-1 opacity-80">Open-source security tools & documentation for web application security standards.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3 p-3 rounded-lg" style="background: rgba(16, 185, 129, 0.05);">
                        <div class="mt-1 flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="m9 12 2 2 4-4"/>
                            </svg>
                        </div>
                        <div>
                            <span class="font-ubuntu text-[1em]" style="color: #10b981;">VPN & Network Security</span>
                            <p class="text-[0.85em] mt-1 opacity-80">Built StealthGuard VPN — OpenVPN tunneling, IP masking, end-to-end encryption.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3 p-3 rounded-lg" style="background: rgba(16, 185, 129, 0.05);">
                        <div class="mt-1 flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="m9 12 2 2 4-4"/>
                            </svg>
                        </div>
                        <div>
                            <span class="font-ubuntu text-[1em]" style="color: #10b981;">AI Surveillance Patent</span>
                            <p class="text-[0.85em] mt-1 opacity-80">AI-based CCTV anomaly detection (Patent No: 202521049739).</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3 p-3 rounded-lg" style="background: rgba(16, 185, 129, 0.05);">
                        <div class="mt-1 flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="m9 12 2 2 4-4"/>
                            </svg>
                        </div>
                        <div>
                            <span class="font-ubuntu text-[1em]" style="color: #10b981;">Secure Architecture</span>
                            <p class="text-[0.85em] mt-1 opacity-80">RBAC, input sanitization, serverless auth, and secure data handling.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3 p-3 rounded-lg" style="background: rgba(16, 185, 129, 0.05);">
                        <div class="mt-1 flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="m9 12 2 2 4-4"/>
                            </svg>
                        </div>
                        <div>
                            <span class="font-ubuntu text-[1em]" style="color: #10b981;">Vulnerability Management</span>
                            <p class="text-[0.85em] mt-1 opacity-80">Exposure management, threat detection pipelines, and enterprise security.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3 p-3 rounded-lg" style="background: rgba(16, 185, 129, 0.05);">
                        <div class="mt-1 flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="m9 12 2 2 4-4"/>
                            </svg>
                        </div>
                        <div>
                            <span class="font-ubuntu text-[1em]" style="color: #10b981;">ML & Deep Learning</span>
                            <p class="text-[0.85em] mt-1 opacity-80">Coursera Specialization — applied to security and AI systems.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
